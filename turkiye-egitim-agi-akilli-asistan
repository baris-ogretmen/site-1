        function handleFirebaseError(error, context) {
            const errorBox = document.getElementById('auth-error-box');
            if(errorBox) errorBox.classList.remove('hidden');
            
            if (error.code === 'auth/operation-not-allowed') {
                if(errorBox) errorBox.innerHTML = `⚠️ <b>KAYIT HATASI:</b><br>Firebase'de <b>Anonymous (Anonim)</b> giriş kapalı.`;
            } else if (error.code === 'permission-denied') {
                if(errorBox) errorBox.innerHTML = `⚠️ <b>VERİTABANI İZNİ HATASI:</b><br>Lütfen Firebase'den izni açın.`;
            } else {
                if(errorBox) errorBox.innerHTML = `⚠️ Bir sorun oluştu: <br><span class="text-xs">${error.message}</span>`;
            }
            console.error("Firebase Error in " + context + ":", error);
            showToast("İşlem başarısız oldu.", "error");
        }

        async function init() {
            try { 
                if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
                    await signInWithCustomToken(auth, __initial_auth_token);
                } else {
                    await signInAnonymously(auth); 
                }
            } catch (error) { 
                console.error("Auth init error:", error);
                document.getElementById('loading-view').classList.add('opacity-0', 'pointer-events-none');
                setTimeout(() => document.getElementById('loading-view').classList.add('hidden'), 500);
                showView('login');
            }
        }

        onAuthStateChanged(auth, (user) => {
            if (user) {
                currentUser = user;
                startDataListeners();
                
                if(user.email) {
                    isAdminActive = true;
                    document.getElementById('loading-view').classList.add('opacity-0', 'pointer-events-none');
                    setTimeout(() => document.getElementById('loading-view').classList.add('hidden'), 500);
                    closeAdminLoginModal();
                    showView('admin');
                    return;
                } else {
                    isAdminActive = false;
                }
                
                const savedTeacher = sessionStorage.getItem('rehab_teacher_id');
                if (savedTeacher) {
                    setTimeout(() => {
                        const teacher = allTeachers.find(t => t.id === savedTeacher);
                        if (teacher) { currentTeacher = teacher; updateUI(); showView('dashboard'); } 
                        else { showView('login'); }
                        document.getElementById('loading-view').classList.add('opacity-0', 'pointer-events-none');
                        setTimeout(() => document.getElementById('loading-view').classList.add('hidden'), 500);
                    }, 800);
