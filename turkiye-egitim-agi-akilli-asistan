            if(currentTeacher.kurumTuru === 'Rehabilitasyon Merkezi') {
                lbl.innerText = "Tanı Durumu"; extLbl.innerText = "Destek İhtiyacı";
            } else if(currentTeacher.kurumTuru.includes('Okul')) {
                lbl.innerText = "Sınıf ve Şube"; extLbl.innerText = "Kulüp/Eğilim";
            } else if(currentTeacher.kurumTuru === 'Özel Öğretim Kursu') {
                lbl.innerText = "Alan / Seviye"; extLbl.innerText = "Hedef Sınav";
            } else if(currentTeacher.kurumTuru === 'Kreş / Anaokulu') {
                lbl.innerText = "Yaş / Sınıf"; extLbl.innerText = "Özel Durum";
            } else {
                lbl.innerText = "Bilgi / Seviye";
            }

            if(student.extra) {
                extBox.classList.remove('hidden');
                extTxt.innerText = student.extra;
            } else {
                extBox.classList.add('hidden');
            }

            const initialEl = document.getElementById('detail-student-initial');
            initialEl.innerText = student.name.split(' ').map(n => n[0]).join('').substring(0, 2).toUpperCase();
            initialEl.style.background = getGradientForName(student.name);

            const actionsDiv = document.getElementById('student-actions');
            if(student.addedById === currentTeacher.id) actionsDiv.classList.remove('hidden'); else actionsDiv.classList.add('hidden');

            if(!isUpdate) { 
                document.getElementById('new-note-content').value = ''; 
                document.querySelector('input[name="note-type"][value="info"]').checked = true; 
                loadQuickNotes(); 
                showView('student-detail'); 
            }
            renderNotes();
        }

        window.openEditStudentModal = function() {
            const student = allStudents.find(s => s.id === currentStudentId); if(!student) return;
            document.getElementById('modal-title').innerText = "Öğrenciyi Düzenle"; 
            document.getElementById('edit-student-id').value = student.id;
            document.getElementById('student-name').value = student.name; 
            document.getElementById('student-age').value = student.age;
            document.getElementById('student-diagnosis').value = student.diagnosis !== 'Belirtilmedi' ? student.diagnosis : ''; 
            document.getElementById('student-extra').value = student.extra || ''; 
            openStudentModalForAdd();
        }

        let deleteAction = null;
        window.closeConfirmModal = function() {
            const modal = document.getElementById('confirm-modal'); const content = document.getElementById('confirm-modal-content');
            modal.classList.add('opacity-0'); content.classList.add('scale-95'); setTimeout(() => modal.classList.add('hidden'), 200); deleteAction = null;
        }

        function showConfirm(title, message, action) {
            document.getElementById('confirm-title').innerText = title; document.getElementById('confirm-message').innerText = message; deleteAction = action;
            const modal = document.getElementById('confirm-modal'); const content = document.getElementById('confirm-modal-content');
            modal.classList.remove('hidden'); setTimeout(() => { modal.classList.remove('opacity-0'); content.classList.remove('scale-95'); }, 10);
        }

        document.getElementById('confirm-action-btn').addEventListener('click', async () => { if(deleteAction) await deleteAction(); closeConfirmModal(); });

        window.deleteStudent = function() {
            showConfirm("Öğrenciyi Sil?", "Öğrenci ve ona ait TÜM notlar silinecektir.", async () => {
                try {
                    const studentNotes = allNotes.filter(n => n.studentId === currentStudentId);
                    for(let note of studentNotes) await deleteDoc(getPubDoc('notes_tr', note.id)); 
                    await deleteDoc(getPubDoc('students_tr', currentStudentId));
                    showToast("Öğrenci ve notları başarıyla silindi.", "success", "🗑️"); showView('dashboard');
                } catch(e) { console.error(e); showToast("Silme hatası.", "error"); }
            });
        }

        function shootConfetti() {
            const emojis = ['⭐', '🎉', '👏', '🚀', '🌟', '🏆'];
            for(let i=0; i<45; i++) {
                const el = document.createElement('div');
                el.innerText = emojis[Math.floor(Math.random()*emojis.length)];
                el.style.position = 'fixed';
                el.style.left = Math.random() * 100 + 'vw';
                el.style.top = '-50px';
                el.style.fontSize = (Math.random() * 25 + 15) + 'px';
                el.style.zIndex = 9999;
                el.style.pointerEvents = 'none';
                el.style.transition = 'all 2.5s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
                document.body.appendChild(el);
                setTimeout(() => {
                    el.style.top = '100vh';
                    el.style.transform = `rotate(${Math.random()*720}deg) translateX(${(Math.random()-0.5)*300}px)`;
                }, 50);
                setTimeout(() => el.remove(), 2500);
            }
        }

        window.appendNote = function(text) {
            const textarea = document.getElementById('new-note-content');
            textarea.value = textarea.value ? textarea.value + " " + text : text;
            textarea.focus();
        }

        window.addNote = async function() {
            if(!currentUser || !currentTeacher || !currentStudentId) return;
            const content = document.getElementById('new-note-content').value.trim(); const type = document.querySelector('input[name="note-type"]:checked').value;
            if (!content) return showToast("Lütfen bir not yazın.", "error");

            try {
                await addDoc(getPubCollection('notes_tr'), { 
                    studentId: currentStudentId, 
                    teacherId: currentTeacher.id, 
                    teacherName: currentTeacher.name, 
                    content: content, 
                    type: type, 
                    kurumKey: currentTeacher.kurumKey, 
                    createdAt: serverTimestamp() 
                });
                document.getElementById('new-note-content').value = ''; 
                showToast("Not başarıyla eklendi.", "success", "📝");
                if(type === 'success') shootConfetti(); 
            } catch (error) { handleFirebaseError(error, "add_note"); }
        }

        window.deleteNote = function(noteId) { 
            showConfirm("Notu Sil?", "Bu gözlem notu kalıcı olarak silinecektir.", async () => { 
                try { 
                    await deleteDoc(getPubDoc('notes_tr', noteId)); 
                    showToast("Not silindi.", "success", "🗑️"); 
                } catch(e) { console.error(e); showToast("Silinemedi.", "error"); } 
            }); 
        }

        function timeAgo(date) {
            const seconds = Math.floor((new Date() - date) / 1000); let interval = seconds / 31536000;
            if (interval > 1) return Math.floor(interval) + " yıl önce"; interval = seconds / 2592000;
            if (interval > 1) return Math.floor(interval) + " ay önce"; interval = seconds / 86400;
            if (interval > 1) { if(Math.floor(interval) === 1) return "Dün"; return Math.floor(interval) + " gün önce"; }
            interval = seconds / 3600; if (interval > 1) return Math.floor(interval) + " saat önce"; interval = seconds / 60;
            if (interval > 1) return Math.floor(interval) + " dakika önce"; return "Az önce";
        }

        function renderNotes() {
            if (!currentStudentId) return;
            const container = document.getElementById('notes-container'); const noNotesMsg = document.getElementById('no-notes-msg'); const badge = document.getElementById('note-count-badge');
            container.innerHTML = '';
            const studentNotes = allNotes.filter(n => n.studentId === currentStudentId); badge.innerText = studentNotes.length;

            if (studentNotes.length === 0) { noNotesMsg.classList.remove('hidden'); } else {
                noNotesMsg.classList.add('hidden'); const fragment = document.createDocumentFragment();
                studentNotes.forEach((note, index) => {
                    let relativeTime = "Şimdi"; let exactTime = "";
                    if (note.createdAt) { const date = note.createdAt.toDate(); relativeTime = timeAgo(date); exactTime = date.toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute:'2-digit' }); }
                    const isMyNote = note.teacherId === currentTeacher.id;
                    let typeBg = "bg-slate-50"; let typeBorder = "border-slate-200"; let typeText = "text-slate-800"; let typeIcon = "📘";
                    if(note.type === 'success') { typeBg = "bg-emerald-50"; typeBorder = "border-emerald-200"; typeText = "text-emerald-900"; typeIcon = "⭐"; } 
                    else if (note.type === 'warning') { typeBg = "bg-orange-50"; typeBorder = "border-orange-200"; typeText = "text-orange-900"; typeIcon = "⚠️"; }

                    const noteEl = document.createElement('div'); 
                    // Dinamik Animasyon ve Tasarım Eklendi
                    noteEl.className = `stagger-item bg-white rounded-[2rem] p-5 sm:p-6 border ${typeBorder} shadow-sm relative group mb-6 print-border transform transition-transform hover:-translate-y-1 hover:shadow-md`;
                    noteEl.style.animationDelay = `${index * 0.08}s`;
                    noteEl.innerHTML = `
                        <!-- Timeline İşaretçisi -->
                        <div class="absolute -left-5 sm:-left-7 top-6 w-3 h-3 rounded-full bg-slate-300 border-2 border-white shadow-sm print-hide"></div>
                        
                        <div class="flex justify-between items-start mb-4">
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 rounded-2xl flex items-center justify-center text-lg font-black ${isMyNote ? 'bg-fuchsia-600 text-white shadow-md shadow-fuchsia-200' : 'bg-slate-200 text-slate-700 shadow-inner'} print-hide transform transition-transform group-hover:scale-105">${note.teacherName.split(' ').map(n => n[0]).join('').substring(0, 2).toUpperCase()}</div>
                                <div><h4 class="font-black text-slate-800 leading-tight text-lg">${note.teacherName} ${isMyNote ? '<span class="text-xs font-bold bg-fuchsia-100 text-fuchsia-600 px-2 py-0.5 rounded-full ml-1 align-middle">Siz</span>' : ''}</h4><span class="text-sm font-bold text-slate-400" title="${exactTime}">${relativeTime}</span></div>
                            </div>
                            ${isMyNote ? `<button onclick="deleteNote('${note.id}')" class="btn-press text-slate-300 hover:text-rose-500 bg-slate-50 hover:bg-rose-50 p-2.5 rounded-xl transition-all opacity-100 sm:opacity-0 group-hover:opacity-100 print-hide" title="Notu Sil"><svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg></button>` : ''}
                        </div>
                        <div class="${typeBg} rounded-2xl p-5 border ${typeBorder} relative overflow-hidden">
                            <span class="absolute right-3 top-3 opacity-20 text-4xl pointer-events-none transform rotate-12">${typeIcon}</span>
                            <p class="whitespace-pre-line text-base font-bold leading-relaxed ${typeText} relative z-10">${escapeHtml(note.content)}</p>
                        </div>
                    `;
                    fragment.appendChild(noteEl);
                });
                container.appendChild(fragment);
            }
        }

        let toastTimeout; function showToast(message, type = 'success', icon = '✨') {
            const toast = document.getElementById('toast'); 
            document.getElementById('toast-message').innerText = message;
            document.getElementById('toast-icon').innerText = icon;
            toast.className = `fixed bottom-8 left-1/2 transform -translate-x-1/2 px-8 py-4 rounded-full shadow-2xl z-[100] flex items-center gap-3 font-bold min-w-[300px] justify-center transition-all duration-400 text-lg ${type === 'success' ? 'bg-slate-900 text-white' : 'bg-rose-600 text-white'}`;
            void toast.offsetWidth; toast.classList.remove('translate-y-32', 'opacity-0');
            clearTimeout(toastTimeout); toastTimeout = setTimeout(() => { toast.classList.add('translate-y-32', 'opacity-0'); }, 4000);
        }
        function escapeHtml(unsafe) { return unsafe.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;"); }
    </script>
</body>
</html>
