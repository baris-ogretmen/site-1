        function startDataListeners() {
            if (!currentUser) return;
            
            // Öğretmenleri dinle
            onSnapshot(getPubCollection('teachers_tr'), (snapshot) => {
                allTeachers = []; snapshot.forEach(doc => { allTeachers.push({ id: doc.id, ...doc.data() }); });
                if(isAdminActive) {
                    document.getElementById('admin-stat-teacher').innerText = allTeachers.length;
                    const uniqueKurums = new Set(allTeachers.map(t => t.kurumKey));
                    document.getElementById('admin-stat-kurum').innerText = uniqueKurums.size;
                }
            }, (error) => {
                if(error.code === 'permission-denied') handleFirebaseError(error, "listener");
            });

            // Öğrencileri dinle
            let studentQuery = null;
            if (isAdminActive) {
                studentQuery = getPubCollection('students_tr');
            } else if (currentTeacher) {
