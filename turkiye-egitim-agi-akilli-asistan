<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Türkiye Eğitim Ağı (TEA) - Akıllı Sistem</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Nunito', sans-serif; -webkit-tap-highlight-color: transparent; background-color: #f8fafc; }
        .hidden { display: none !important; }
        
        /* Animasyonlar */
        .slide-up { animation: slideUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
        .fade-in { animation: fadeIn 0.4s ease-out forwards; }
        .pop-in { animation: popIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; }
        .stagger-item { opacity: 0; animation: popIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; }
        
        @keyframes slideUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        @keyframes popIn { from { opacity: 0; transform: scale(0.90); } to { opacity: 1; transform: scale(1); } }
        
        /* Dinamik Arka Plan */
        .bg-animated { background-size: 200% 200%; animation: gradientMove 15s ease infinite; }
        @keyframes gradientMove { 0% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } 100% { background-position: 0% 50%; } }

        /* Kaydırma Çubuğu */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
        .scrollbar-hide::-webkit-scrollbar { display: none; }

        /* Form ve Seçim Elemanları */
        .cat-radio:checked + div { transform: scale(1.05); box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1); border-width: 2px; }
        .cat-info:checked + div { border-color: #3b82f6; background-color: #eff6ff; color: #1d4ed8;}
        .cat-success:checked + div { border-color: #10b981; background-color: #ecfdf5; color: #047857;}
        .cat-warning:checked + div { border-color: #f59e0b; background-color: #fffbeb; color: #b45309;}
        
        /* Etkileşimli Kartlar */
        .student-card { transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); }
        .student-card:hover { transform: translateY(-5px) scale(1.02); box-shadow: 0 20px 40px -5px rgba(236, 72, 153, 0.15); border-color: #fbcfe8; }
        .btn-press { transition: transform 0.1s; }
        .btn-press:active { transform: scale(0.95); }

        .loader { border: 4px solid #f3f3f3; border-top: 4px solid #ec4899; border-radius: 50%; width: 40px; height: 40px; animation: spin 1s linear infinite; }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        
        .bg-hero { background: linear-gradient(135deg, #4f46e5 0%, #db2777 50%, #f97316 100%); }

        @media print {
            body { background: white !important; }
            body * { visibility: hidden; }
            #student-detail-view, #student-detail-view * { visibility: visible; }
            #student-detail-view { position: absolute; left: 0; top: 0; width: 100%; padding: 0 !important; margin: 0 !important; box-shadow: none !important; }
            button, .print-hide, #navbar, .cat-radio, #quick-notes-area { display: none !important; }
            .bg-slate-50 { background-color: #fff !important; }
            .print-border { border: 1px solid #e2e8f0 !important; margin-bottom: 20px; page-break-inside: avoid; }
            .student-card { break-inside: avoid; }
            #notes-container { padding-top: 20px; }
        }
    </style>
</head>
<body class="text-slate-800 h-screen overflow-hidden flex flex-col bg-gradient-to-br from-indigo-50 via-fuchsia-50 to-pink-50">

    <header class="bg-white/80 backdrop-blur-md border-b border-fuchsia-100 sticky top-0 z-40 hidden print-hide shadow-sm transition-all duration-300" id="navbar">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
            <div class="flex items-center gap-3 cursor-pointer group btn-press" onclick="showView('dashboard')">
                <div class="bg-gradient-to-br from-violet-600 to-pink-500 p-2.5 rounded-xl text-white shadow-md shadow-pink-200 group-hover:scale-110 transition-transform duration-300">
                    <span class="text-xl leading-none">🇹🇷</span>
                </div>
                <div class="flex flex-col">
                    <span class="text-[10px] font-black text-fuchsia-600 tracking-widest uppercase">TÜRKİYE EĞİTİM AĞI</span>
                    <span id="nav-kurum-name" class="font-extrabold text-sm text-slate-800 tracking-tight line-clamp-1 transition-colors group-hover:text-fuchsia-700">Kurum Yükleniyor...</span>
                </div>
            </div>
            
            <div class="flex items-center gap-3 sm:gap-5">
                <button onclick="openAdminSettings()" class="btn-press text-slate-500 hover:text-fuchsia-600 bg-white hover:bg-fuchsia-50 px-3 py-2 rounded-xl transition-all font-bold flex items-center gap-2 shadow-sm border border-slate-200">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                    <span class="hidden md:inline text-sm">Sistem Ayarları</span>
                </button>

                <div class="hidden sm:flex items-center gap-2 bg-white px-4 py-1.5 rounded-full border border-fuchsia-100 shadow-sm transition-all hover:shadow-md">
                    <div class="w-7 h-7 rounded-full bg-gradient-to-br from-violet-500 to-fuchsia-500 text-white flex items-center justify-center font-bold text-xs shadow-inner" id="nav-teacher-initial">A</div>
                    <span id="nav-teacher-name" class="font-bold text-sm text-slate-700">Öğretmen</span>
                </div>
                
                <button onclick="logout()" class="btn-press text-slate-400 hover:text-rose-600 bg-white hover:bg-rose-50 p-2.5 rounded-xl transition-all shadow-sm border border-slate-200" title="Çıkış Yap">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
                </button>
            </div>
        </div>
    </header>

    <main class="flex-1 overflow-y-auto relative w-full" id="main-scroll">
        
        <div id="loading-view" class="absolute inset-0 z-50 flex flex-col items-center justify-center bg-white/95 backdrop-blur-md transition-opacity duration-500">
            <div class="relative w-24 h-24 mb-6">
                <div class="absolute inset-0 rounded-full border-t-4 border-fuchsia-500 animate-spin"></div>
                <div class="absolute inset-2 rounded-full border-r-4 border-pink-400 animate-spin" style="animation-direction: reverse; animation-duration: 1.5s;"></div>
                <div class="absolute inset-4 rounded-full border-b-4 border-violet-500 animate-spin" style="animation-duration: 2s;"></div>
                <div class="absolute inset-0 flex items-center justify-center text-2xl animate-pulse">🇹🇷</div>
            </div>
            <p class="text-fuchsia-600 font-black tracking-widest uppercase animate-pulse text-sm">Türkiye Ağına Bağlanıyor...</p>
        </div>

        <div id="login-view" class="min-h-full w-full flex flex-col lg:flex-row hidden fade-in bg-slate-50">
            
            <div class="w-full lg:w-1/2 bg-hero bg-animated text-white flex flex-col justify-center p-8 sm:p-12 lg:p-16 relative overflow-hidden shadow-2xl z-10 shrink-0 lg:min-h-full">
                <div class="absolute top-0 right-0 w-96 h-96 bg-white opacity-10 rounded-full blur-3xl transform translate-x-1/3 -translate-y-1/3 pointer-events-none transition-transform duration-1000 hover:scale-110"></div>
                <div class="absolute bottom-0 left-0 w-96 h-96 bg-yellow-400 opacity-20 rounded-full blur-3xl transform -translate-x-1/3 translate-y-1/3 pointer-events-none"></div>
                
                <div class="relative z-10 flex flex-col sm:flex-row items-center sm:items-start gap-5 slide-up text-center sm:text-left mt-4 lg:mt-0">
                    <div class="text-5xl bg-white/20 p-5 rounded-[2rem] backdrop-blur-md border border-white/30 shadow-xl transform -rotate-3 mb-2 sm:mb-0 hover:rotate-0 transition-transform duration-300">🇹🇷</div>
                    <div>
                        <h1 class="text-4xl lg:text-5xl font-black uppercase tracking-tight drop-shadow-lg text-white leading-none">Türkiye Eğitim Ağı</h1>
                        <p class="text-pink-200 font-bold tracking-widest text-sm mt-2 uppercase">Akıllı Öğrenci Asistanı</p>
                    </div>
                </div>

                <div class="relative z-10 my-10 lg:my-auto slide-up" style="animation-delay: 0.15s;">
                    <div class="bg-white/10 p-6 rounded-[2rem] backdrop-blur-md border border-white/20 shadow-lg hover:bg-white/20 transition-colors duration-300">
                        <h3 class="font-black text-xl text-yellow-300 mb-4 flex items-center gap-2 justify-center sm:justify-start">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                            Akıllı Sistem Özellikleri
                        </h3>
                        <ul class="text-sm sm:text-base space-y-3 text-indigo-50 font-bold">
                            <li class="flex items-center gap-3 transform hover:translate-x-2 transition-transform"><span class="bg-fuchsia-500/20 p-1.5 rounded-lg text-fuchsia-300">✔️</span> <b>Rehabilitasyonlar:</b> Tanı ve beceri odaklı özel formlar.</li>
                            <li class="flex items-center gap-3 transform hover:translate-x-2 transition-transform"><span class="bg-emerald-500/20 p-1.5 rounded-lg text-emerald-400">✔️</span> <b>Kolej ve Okullar:</b> Sınıf, şube ve akademik takip araçları.</li>
                            <li class="flex items-center gap-3 transform hover:translate-x-2 transition-transform"><span class="bg-blue-500/20 p-1.5 rounded-lg text-blue-300">✔️</span> <b>Öğretim Kursları:</b> Hedef sınav ve net odaklı hızlı notlar.</li>
                            <li class="flex items-center gap-3 transform hover:translate-x-2 transition-transform"><span class="bg-orange-500/20 p-1.5 rounded-lg text-orange-300">✔️</span> <b>Kreşler:</b> Yaş grubu ve günlük uyku/yemek takipleri.</li>
                            <li class="flex items-center gap-3 transform hover:translate-x-2 transition-transform"><span class="bg-pink-500/20 p-1.5 rounded-lg text-pink-300">✔️</span> <b>Tam Güvenlik:</b> Sadece kurucu Firebase hesabından erişilen Admin Paneli.</li>
                        </ul>
                    </div>
                </div>

                <div class="relative z-10 text-indigo-200/80 text-xs sm:text-sm font-bold text-center sm:text-left mb-4 lg:mb-0 slide-up" style="animation-delay: 0.3s;">
                    Tam İzolasyon • Firebase Güvencesi • Yapay Zeka Mantığı
                </div>
            </div>

            <div class="w-full lg:w-1/2 flex items-start sm:items-center justify-center p-4 sm:p-12 relative z-0">
                <div class="w-full max-w-md pop-in bg-white p-6 sm:p-10 rounded-[2.5rem] shadow-2xl shadow-indigo-100/80 border border-slate-100 -mt-10 sm:-mt-0 relative z-20 transition-all duration-300 hover:shadow-indigo-200/80">
                    <div class="text-center mb-8">
                        <h2 class="text-2xl sm:text-3xl font-black text-slate-800 tracking-tight">Ağa Katılın</h2>
                        <p class="text-slate-500 mt-2 font-bold text-sm">Giriş yapın veya yeni bir kurum profili oluşturun.</p>
                    </div>

                    <div class="flex gap-2 mb-6 bg-slate-100 p-1.5 rounded-2xl relative shadow-inner">
                        <button type="button" onclick="setAuthMode('login')" id="tab-login" class="flex-1 py-3 rounded-xl bg-white shadow-md font-black text-fuchsia-600 transition-all text-sm uppercase tracking-wide btn-press">Giriş Yap</button>
                        <button type="button" onclick="setAuthMode('register')" id="tab-register" class="flex-1 py-3 rounded-xl font-bold text-slate-500 hover:text-slate-800 transition-all text-sm uppercase tracking-wide btn-press">Yeni Kayıt</button>
                    </div>

                    <form id="auth-form" class="space-y-4">
                        <div class="group">
                            <label class="block text-sm font-bold text-slate-700 mb-1.5 ml-1 transition-colors group-focus-within:text-fuchsia-600">Adınız Soyadınız</label>
                            <input type="text" id="auth-name" required placeholder="Örn: Ahmet Yılmaz" class="w-full px-5 py-4 rounded-2xl bg-slate-50 border border-slate-200 focus:bg-white focus:border-fuchsia-500 focus:ring-4 focus:ring-fuchsia-50 outline-none transition-all text-slate-800 font-bold text-base shadow-sm">
                        </div>
                        <div class="group">
                            <label class="block text-sm font-bold text-slate-700 mb-1.5 ml-1 transition-colors group-focus-within:text-fuchsia-600">Şifreniz</label>
                            <input type="password" id="auth-password" required placeholder="••••••••" class="w-full px-5 py-4 rounded-2xl bg-slate-50 border border-slate-200 focus:bg-white focus:border-fuchsia-500 focus:ring-4 focus:ring-fuchsia-50 outline-none transition-all text-slate-800 font-bold text-base shadow-sm">
                        </div>
                        
                        <div id="register-fields" class="space-y-4 hidden slide-up bg-fuchsia-50/50 p-5 sm:p-6 rounded-3xl border border-fuchsia-100 mt-4">
                            <div class="flex items-center gap-2 mb-2">
                                <span class="text-fuchsia-600 text-lg">🏫</span>
                                <h4 class="font-black text-fuchsia-800 text-sm uppercase tracking-wider">Kurum Bilgileri</h4>
                            </div>
                            
                            <div>
                                <label class="block text-xs font-bold text-slate-500 mb-1 ml-1">Kurum Türü (Sistem buna göre değişir)</label>
                                <select id="auth-kurum-turu" class="w-full px-4 py-3.5 rounded-xl bg-white border border-slate-200 focus:border-fuchsia-500 focus:ring-4 focus:ring-fuchsia-50 outline-none transition-all text-slate-800 font-bold appearance-none cursor-pointer shadow-sm text-sm">
                                    <option value="Rehabilitasyon Merkezi">Rehabilitasyon Merkezi</option>
                                    <option value="Kolej / Özel Okul">Kolej / Özel Okul</option>
                                    <option value="Devlet Okulu">Devlet Okulu</option>
                                    <option value="Özel Öğretim Kursu">Özel Öğretim Kursu</option>
                                    <option value="Kreş / Anaokulu">Kreş / Anaokulu</option>
                                    <option value="Bireysel Eğitmen">Bireysel Eğitmen</option>
                                    <option value="Diğer">Diğer</option>
                                </select>
                            </div>

                            <div class="grid grid-cols-2 gap-3" id="auth-location-grid">
                                <div>
                                    <label class="block text-xs font-bold text-slate-500 mb-1 ml-1">İl</label>
                                    <select id="auth-il" class="w-full px-4 py-3.5 rounded-xl bg-white border border-slate-200 focus:border-fuchsia-500 focus:ring-4 focus:ring-fuchsia-50 outline-none transition-all text-slate-800 font-bold appearance-none cursor-pointer shadow-sm text-sm">
                                        <option value="" disabled selected>İl Seçin</option>
                                    </select>
                                </div>
                                <div>
                                    <label class="block text-xs font-bold text-slate-500 mb-1 ml-1">İlçe</label>
                                    <select id="auth-ilce" class="w-full px-4 py-3.5 rounded-xl bg-white border border-slate-200 focus:border-fuchsia-500 focus:ring-4 focus:ring-fuchsia-50 outline-none transition-all text-slate-800 font-bold appearance-none cursor-pointer shadow-sm text-sm">
                                        <option value="" disabled selected>Önce İl</option>
                                    </select>
                                </div>
                            </div>
                            
                            <div id="auth-kurum-container">
                                <label class="block text-xs font-bold text-slate-500 mb-1 ml-1">Okul / Kurum Adı</label>
                                <input type="text" id="auth-kurum" placeholder="Örn: Atatürk İlkokulu" class="w-full px-4 py-3.5 rounded-xl bg-white border border-slate-200 focus:border-fuchsia-500 focus:ring-4 focus:ring-fuchsia-50 outline-none transition-all text-slate-800 font-bold shadow-sm text-sm">
                            </div>
                        </div>

                        <div id="auth-error-box" class="hidden slide-up bg-rose-50 border border-rose-200 text-rose-700 p-4 rounded-xl text-sm font-bold text-center mt-2">
                            Hata Mesajı
                        </div>

                        <button type="submit" id="auth-submit-btn" class="btn-press w-full bg-gradient-to-r from-violet-600 to-fuchsia-600 hover:from-violet-700 hover:to-fuchsia-700 text-white font-black text-lg py-4 rounded-2xl transition-all shadow-xl shadow-fuchsia-200 mt-6 h-14 flex items-center justify-center gap-2 transform hover:-translate-y-1">
                            Giriş Yap
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div id="dashboard-view" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 hidden pb-24">
            <div class="flex flex-col md:flex-row justify-between items-center mb-8 bg-white border border-slate-200 p-6 sm:p-8 rounded-[2rem] shadow-sm relative overflow-hidden slide-up">
                <div class="absolute -right-10 -top-10 w-40 h-40 bg-gradient-to-br from-fuchsia-100 to-pink-100 rounded-full blur-3xl opacity-60"></div>
                <div class="absolute -left-10 -bottom-10 w-40 h-40 bg-gradient-to-tr from-violet-100 to-indigo-100 rounded-full blur-3xl opacity-60"></div>
                
                <div class="text-center md:text-left relative z-10">
                    <span id="dash-kurum-turu" class="bg-fuchsia-100 text-fuchsia-700 px-4 py-1.5 rounded-xl text-xs font-black uppercase tracking-widest border border-fuchsia-200 shadow-sm inline-block transform hover:scale-105 transition-transform cursor-default">Kurum Türü</span>
                    <h2 class="text-3xl md:text-4xl font-black text-slate-800 mt-4 tracking-tight" id="dash-kurum-title">Okul Adı</h2>
                    <p class="text-sm font-bold text-slate-500 flex items-center justify-center md:justify-start gap-1.5 mt-2">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-fuchsia-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                        <span id="dash-kurum-loc">İl / İlçe</span>
                    </p>
                </div>
                <div class="mt-8 md:mt-0 flex gap-4 text-center relative z-10 w-full md:w-auto">
                    <div class="flex-1 md:flex-none bg-white/80 backdrop-blur-md px-6 py-5 rounded-2xl border border-slate-200 shadow-sm transform hover:-translate-y-1 transition-transform">
                        <p class="text-xs font-black text-slate-400 uppercase tracking-widest mb-1">Öğrenci</p>
                        <p class="text-4xl font-black text-violet-600" id="stat-students">0</p>
                    </div>
                    <div class="flex-1 md:flex-none bg-white/80 backdrop-blur-md px-6 py-5 rounded-2xl border border-slate-200 shadow-sm transform hover:-translate-y-1 transition-transform" style="animation-delay: 0.1s;">
                        <p class="text-xs font-black text-slate-400 uppercase tracking-widest mb-1">Gözlem</p>
                        <p class="text-4xl font-black text-pink-600" id="stat-notes">0</p>
                    </div>
                </div>
            </div>

            <div class="bg-white p-2.5 rounded-[2rem] border border-slate-200 shadow-sm flex flex-col sm:flex-row gap-3 mb-8 sticky top-20 z-30 slide-up" style="animation-delay: 0.1s;">
                <div class="relative flex-1 group">
                    <div class="absolute inset-y-0 left-0 pl-6 flex items-center pointer-events-none">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-slate-400 group-focus-within:text-fuchsia-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                    </div>
                    <input type="text" id="search-student" oninput="filterStudents()" placeholder="Öğrencilerde ara..." class="w-full pl-16 pr-6 py-4 rounded-full bg-slate-50 border-0 focus:ring-0 focus:bg-slate-100 outline-none font-bold text-lg text-slate-800 placeholder-slate-400 transition-all">
                </div>
                <button onclick="openStudentModalForAdd()" class="btn-press bg-gradient-to-r from-violet-600 to-fuchsia-600 hover:from-violet-700 hover:to-fuchsia-700 text-white px-8 py-4 rounded-full font-black transition-transform transform hover:-translate-y-0.5 shadow-lg shadow-fuchsia-200 flex items-center justify-center gap-2 sm:w-auto w-full text-lg">
                    <span class="text-2xl leading-none -mt-1">+</span> <span id="btn-add-text">Öğrenci Ekle</span>
                </button>
            </div>

            <div id="students-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6"></div>
            
