                onSnapshot(studentQuery, (snapshot) => {
                    allStudents = []; snapshot.forEach(doc => { allStudents.push({ id: doc.id, ...doc.data() }); });
                    allStudents.sort((a, b) => {
                        const timeA = a.updatedAt ? a.updatedAt.toMillis() : (a.createdAt ? a.createdAt.toMillis() : 0);
                        const timeB = b.updatedAt ? b.updatedAt.toMillis() : (b.createdAt ? b.createdAt.toMillis() : 0);
                        return timeB - timeA;
                    });
                    
                    if(isAdminActive) {
                        document.getElementById('admin-stat-student').innerText = allStudents.length;
                    }
                    
                    if(currentTeacher) {
                        const myStudents = allStudents.filter(s => s.kurumKey === currentTeacher.kurumKey);
                        document.getElementById('stat-students').innerText = myStudents.length;
                        renderStudents(document.getElementById('search-student') ? document.getElementById('search-student').value : '');
                    }
                    
                    if(currentStudentId && !document.getElementById('student-detail-view').classList.contains('hidden')) {
                        const currentStudent = allStudents.find(s => s.id === currentStudentId);
                        if(currentStudent) openStudentDetail(currentStudent, true);
                        else showView('dashboard'); 
                    }

                    if(isAdminActive && !document.getElementById('admin-view').classList.contains('hidden')) renderAdminStudents();
                }, (error) => {
                    console.error("Students listener error", error);
                });
            }

            // Notları dinle
            let notesQuery = null;
            if (isAdminActive) {
                notesQuery = getPubCollection('notes_tr');
            } else if (currentTeacher) {
                notesQuery = query(getPubCollection('notes_tr'), where("kurumKey", "==", currentTeacher.kurumKey));
            }

            if (notesQuery) {
                onSnapshot(notesQuery, (snapshot) => {
                    allNotes = []; snapshot.forEach(doc => { allNotes.push({ id: doc.id, ...doc.data() }); });
                    allNotes.sort((a, b) => {
                        const timeA = a.createdAt ? a.createdAt.toMillis() : Date.now();
                        const timeB = b.createdAt ? b.createdAt.toMillis() : Date.now();
                        return timeB - timeA;
                    });
                    
                    if(isAdminActive) {
                        document.getElementById('admin-stat-note').innerText = allNotes.length;
                    }

                    if(currentTeacher) {
                        const myStudentsIds = allStudents.filter(s => s.kurumKey === currentTeacher.kurumKey).map(s => s.id);
                        const myKurumNotes = allNotes.filter(n => myStudentsIds.includes(n.studentId));
                        document.getElementById('stat-notes').innerText = myKurumNotes.length;
                        
                        // Öğrenci listesini de notlar gelince güncelle (Son işlem zamanı için)
                        if(document.getElementById('dashboard-view') && !document.getElementById('dashboard-view').classList.contains('hidden')) {
                            renderStudents(document.getElementById('search-student') ? document.getElementById('search-student').value : '');
                        }
                    }
                    if (currentStudentId) renderNotes();
                }, (error) => {
                    console.error("Notes listener error", error);
                });
            }
        }

